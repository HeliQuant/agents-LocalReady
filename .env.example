# ── agents-LocalReady · your local HeliQuant engine ──────────────────────────
# Copy this file to `.env`, then `docker compose up -d`.
#
# REQUIRED — enables the web onboarding (POST /register). Make it long + random.
HQ_SETUP_TOKEN=change-me-to-a-long-random-string

# Everything below is OPTIONAL here. The easiest path is to leave the keys blank and submit them through
# the web onboarding form on the HeliQuant dApp (/onboarding) — it POSTs them straight into THIS engine's
# local SQLite. Nothing leaves your machine either way.
#
# GROQ_API_KEY=gsk_xxx,gsk_yyy,gsk_zzz       # comma-separated — 10 free keys recommended
# BITGET_API_KEY=
# BITGET_API_SECRET=
# BITGET_PASSPHRASE=
# BITGET_DEMO=1                              # 1 = demo (no real funds) · 0 = mainnet
# BITGET_EXECUTE=0                           # 1 = place real Bitget DEMO orders (BTC/ETH/XRP)
# DEPLOYER_PRIVATE_KEY=                      # testnet wallet only (on-chain anchoring)
# ALLORA_API_KEY=
# NANSEN_API_KEY=
# ELFA_API_KEY=
# MANTLESCAN_API_KEY=

# Firm config (sensible defaults — override if you like)
ASSETS=BTC,ETH,SOL,HYPE,SUI,XRP
INTERVAL_MIN=30
REFRESH_DATA=1
